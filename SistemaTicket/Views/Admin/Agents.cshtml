@{
    ViewData["Title"] = "Agentes";
    ViewData["Breadcrumb"] = "6.6 Agentes";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-xl font-bold text-gray-900">👤 Agentes</h1>
        <p class="text-sm text-gray-500 mt-0.5">Admin Panel › Agents › Agents</p>
    </div>
    <button onclick="document.getElementById('modalNewAgent').classList.remove('hidden')" class="btn-primary btn-sm">+ Nuevo Agente</button>
</div>

<div class="card overflow-hidden mb-6">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-slate-50 border-b border-gray-100">
                <th class="table-th">Agente</th>
                <th class="table-th">Username</th>
                <th class="table-th">Depto Principal</th>
                <th class="table-th">Rol</th>
                <th class="table-th">Deptos Adicionales</th>
                <th class="table-th">Tickets</th>
                <th class="table-th">Estado</th>
                <th class="table-th"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
            <tr class="hover:bg-slate-50/60">
                <td class="table-td">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold flex-shrink-0">VR</div>
                        <div>
                            <div class="font-semibold text-gray-800">Valentina Ruiz</div>
                            <div class="text-xs text-gray-400">v.ruiz@empresa.cl</div>
                        </div>
                    </div>
                </td>
                <td class="table-td text-gray-500 font-mono text-xs">v.ruiz</td>
                <td class="table-td">Soporte Técnico</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Administrador</span></td>
                <td class="table-td text-xs text-gray-400">Hardware, RRHH</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">12</span></td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activo</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
            <tr class="hover:bg-slate-50/60">
                <td class="table-td">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-xs font-bold flex-shrink-0">MF</div>
                        <div>
                            <div class="font-semibold text-gray-800">Matías Fernández</div>
                            <div class="text-xs text-gray-400">m.fernandez@empresa.cl</div>
                        </div>
                    </div>
                </td>
                <td class="table-td text-gray-500 font-mono text-xs">m.fernandez</td>
                <td class="table-td">Hardware</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Staff Técnico</span></td>
                <td class="table-td text-xs text-gray-400">—</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">8</span></td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activo</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
            <tr class="hover:bg-slate-50/60">
                <td class="table-td">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold flex-shrink-0">SM</div>
                        <div>
                            <div class="font-semibold text-gray-800">Sofía Morales</div>
                            <div class="text-xs text-gray-400">s.morales@empresa.cl</div>
                        </div>
                    </div>
                </td>
                <td class="table-td text-gray-500 font-mono text-xs">s.morales</td>
                <td class="table-td">Facturación</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Staff Técnico</span></td>
                <td class="table-td text-xs text-gray-400">RRHH</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">5</span></td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activo</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
            <tr class="hover:bg-slate-50/60">
                <td class="table-td">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold flex-shrink-0">DC</div>
                        <div>
                            <div class="font-semibold text-gray-800">Diego Castillo</div>
                            <div class="text-xs text-gray-400">d.castillo@empresa.cl</div>
                        </div>
                    </div>
                </td>
                <td class="table-td text-gray-500 font-mono text-xs">d.castillo</td>
                <td class="table-td">Soporte Técnico</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-700">Supervisor</span></td>
                <td class="table-td text-xs text-gray-400">Facturación</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">7</span></td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
        </tbody>
    </table>
</div>

<div class="card p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">📋 Referencia de Permisos</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-indigo-400 flex-shrink-0"></span>Ver tickets asignados</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-indigo-400 flex-shrink-0"></span>Responder y anotar</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-indigo-400 flex-shrink-0"></span>Reasignar tickets</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-indigo-400 flex-shrink-0"></span>Cerrar tickets</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-purple-400 flex-shrink-0"></span>Crear tickets manuales</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-purple-400 flex-shrink-0"></span>Gestionar usuarios</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-red-400 flex-shrink-0"></span>Cambiar configuración</div>
        <div class="flex items-center gap-2 text-xs text-gray-600 bg-slate-50 rounded-lg px-3 py-2"><span class="w-2 h-2 rounded-full bg-red-400 flex-shrink-0"></span>Eliminar tickets</div>
    </div>
</div>

<div id="modalNewAgent" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h3 class="text-base font-semibold">Nuevo Agente</h3>
            <button onclick="document.getElementById('modalNewAgent').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
        </div>
        <div class="p-5 space-y-3">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="form-label">Nombre <span class="text-red-500">*</span></label>
                    <input type="text" class="form-input" placeholder="Nombre completo" />
                </div>
                <div>
                    <label class="form-label">Teléfono</label>
                    <input type="tel" class="form-input" placeholder="+56 9 XXXX XXXX" />
                </div>
            </div>
            <div>
                <label class="form-label">Email <span class="text-red-500">*</span></label>
                <input type="email" class="form-input" placeholder="agente@empresa.cl" />
            </div>
            <div>
                <label class="form-label">Username <span class="text-red-500">*</span></label>
                <input type="text" class="form-input" placeholder="ej. v.ruiz" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="form-label">Departamento principal</label>
                    <select class="form-select">
                        <option>Soporte Técnico</option>
                        <option>Hardware</option>
                        <option>Facturación</option>
                        <option>RRHH</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Rol</label>
                    <select class="form-select">
                        <option>Staff Técnico</option>
                        <option>Supervisor</option>
                        <option>Administrador</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="form-label">Contraseña temporal</label>
                <div class="flex gap-2">
                    <input type="password" class="form-input" placeholder="••••••••" />
                    <button class="btn-secondary btn-sm whitespace-nowrap">Generar</button>
                </div>
            </div>
            <label class="flex items-center gap-2 text-xs text-gray-600 cursor-pointer">
                <input type="checkbox" class="rounded border-gray-300 text-indigo-600" />
                Forzar cambio de contraseña en primer inicio de sesión
            </label>
        </div>
        <div class="flex justify-end gap-2 px-5 py-4 border-t border-gray-100">
            <button onclick="document.getElementById('modalNewAgent').classList.add('hidden')" class="btn-secondary btn-sm">Cancelar</button>
            <button class="btn-primary btn-sm">Guardar Agente</button>
        </div>
    </div>
</div>
