@{
    ViewData["Title"] = "Departamentos";
    ViewData["Breadcrumb"] = "6.4 Departamentos";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Page Banner -->
<div class="relative mb-6 rounded-2xl overflow-hidden shadow-lg" style="background-image: url('/img/fondo1.png'); background-size: cover; background-position: center;">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(29,78,216,0.82) 0%, rgba(37,99,235,0.78) 45%, rgba(14,165,233,0.72) 100%);"></div>
    <div class="absolute inset-0 opacity-5" style="background-image:repeating-linear-gradient(0deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px),repeating-linear-gradient(90deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px);"></div>
    <div class="relative z-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 px-7 py-5">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-white/20 ring-2 ring-white/30 flex items-center justify-center text-2xl shadow-inner select-none">🏢</div>
            <div>
                <p class="text-blue-200 text-xs font-semibold uppercase tracking-widest mb-0.5">Admin Panel › Organización</p>
                <h1 class="text-xl font-extrabold text-white leading-tight drop-shadow-sm">Departamentos</h1>
                <p class="text-blue-200/80 text-xs mt-0.5">Estructura y áreas de atención</p>
            </div>
        </div>
        <button onclick="document.getElementById('modalNewDept').classList.remove('hidden')" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white text-blue-700 text-sm font-bold shadow-md hover:bg-blue-50 active:scale-95 transition-all flex-shrink-0">+ Nuevo Departamento</button>
    </div>
</div>

<div class="card overflow-hidden mb-6">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-slate-50 border-b border-gray-100">
                <th class="table-th">Nombre</th>
                <th class="table-th">Tipo</th>
                <th class="table-th">Manager</th>
                <th class="table-th">SLA</th>
                <th class="table-th">Agentes</th>
                <th class="table-th">Tickets</th>
                <th class="table-th">Estado</th>
                <th class="table-th"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
            <tr class="hover:bg-slate-50/60">
                <td class="table-td font-semibold text-gray-800">Soporte Técnico</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">Público</span></td>
                <td class="table-td">
                    <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold">VR</div>
                        <span class="text-gray-600">Matias Robles</span>
                    </div>
                </td>
                <td class="table-td text-gray-500 text-xs">Normal 8h</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">2</span></td>
                <td class="table-td text-gray-600">18</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activa</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
            <tr class="hover:bg-slate-50/60">
                <td class="table-td font-semibold text-gray-800">Hardware</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">Público</span></td>
                <td class="table-td">
                    <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-xs font-bold">MF</div>
                        <span class="text-gray-600">Matías Fernández</span>
                    </div>
                </td>
                <td class="table-td text-gray-500 text-xs">Normal 8h</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">1</span></td>
                <td class="table-td text-gray-600">9</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activa</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
            <tr class="hover:bg-slate-50/60">
                <td class="table-td font-semibold text-gray-800">Facturación</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">Público</span></td>
                <td class="table-td">
                    <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold">SM</div>
                        <span class="text-gray-600">Sofía Morales</span>
                    </div>
                </td>
                <td class="table-td text-gray-500 text-xs">Alto 4h</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">1</span></td>
                <td class="table-td text-gray-600">11</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activa</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
            <tr class="hover:bg-slate-50/60">
                <td class="table-td font-semibold text-gray-800">RRHH</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Privado</span></td>
                <td class="table-td text-gray-400 text-xs">Sin asignar</td>
                <td class="table-td text-gray-500 text-xs">Bajo 3d</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">0</span></td>
                <td class="table-td text-gray-600">3</td>
                <td class="table-td"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactiva</span></td>
                <td class="table-td"><button class="text-gray-400 hover:text-indigo-600 transition-colors">✏️</button></td>
            </tr>
        </tbody>
    </table>
</div>

<div id="modalNewDept" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-xl">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h3 class="text-base font-semibold">Nuevo Departamento</h3>
            <button onclick="document.getElementById('modalNewDept').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
        </div>
        <div class="p-5 space-y-3">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="form-label">Nombre <span class="text-red-500">*</span></label>
                    <input type="text" class="form-input" placeholder="ej. Soporte Técnico" />
                </div>
                <div>
                    <label class="form-label">Tipo</label>
                    <select class="form-select">
                        <option>Público</option>
                        <option>Privado</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="form-label">Manager</label>
                    <select class="form-select">
                        <option>— Sin manager —</option>
                        <option>Matias Robles</option>
                        <option>Matías Fernández</option>
                        <option>Sofía Morales</option>
                        <option>Diego Castillo</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">SLA</label>
                    <select class="form-select">
                        <option>Normal (8h laboral)</option>
                        <option>Alto (4h laboral)</option>
                        <option>Crítico (1h 24/7)</option>
                        <option>Bajo (3d laboral)</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="form-label">Horario</label>
                    <select class="form-select">
                        <option>Horario Laboral Chile</option>
                        <option>24/7 Ininterrumpido</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Email saliente</label>
                    <select class="form-select">
                        <option>soporte@empresa.cl</option>
                        <option>facturacion@empresa.cl</option>
                    </select>
                </div>
            </div>
            <div class="flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2">
                <span class="text-xs text-gray-600">Auto-respuesta a nuevos tickets</span>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" class="sr-only peer" />
                    <div class="w-9 h-5 bg-gray-200 rounded-full peer peer-checked:bg-indigo-500 after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"></div>
                </label>
            </div>
            <div>
                <label class="form-label">Firma del departamento</label>
                <textarea class="form-input" rows="3" placeholder="Texto de firma para emails salientes..."></textarea>
            </div>
        </div>
        <div class="flex justify-end gap-2 px-5 py-4 border-t border-gray-100">
            <button onclick="document.getElementById('modalNewDept').classList.add('hidden')" class="btn-secondary btn-sm">Cancelar</button>
            <button class="btn-primary btn-sm">Guardar Departamento</button>
        </div>
    </div>
</div>
