@{
    ViewData["Title"] = "Dashboard";
    ViewData["Breadcrumb"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Hero Banner -->
<div class="relative mb-6 rounded-2xl overflow-hidden shadow-lg" style="background-image: url('/img/fondo1.png'); background-size: cover; background-position: center;">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(29,78,216,0.82) 0%, rgba(37,99,235,0.78) 45%, rgba(14,165,233,0.72) 100%);"></div>
    <!-- Decorative blobs -->
    <div class="absolute -top-10 -right-10 w-52 h-52 rounded-full opacity-20" style="background:radial-gradient(circle, #bfdbfe, transparent 70%);"></div>
    <div class="absolute bottom-0 left-1/3 w-72 h-24 rounded-full opacity-10" style="background:radial-gradient(ellipse, #fff, transparent 70%);"></div>
    <div class="absolute top-0 left-0 w-40 h-40 rounded-full opacity-10" style="background:radial-gradient(circle, #60a5fa, transparent 70%);"></div>
    <!-- Grid lines overlay -->
    <div class="absolute inset-0 opacity-5" style="background-image:repeating-linear-gradient(0deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px),repeating-linear-gradient(90deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px);"></div>

    <div class="relative z-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5 px-7 py-6">
        <!-- Left: avatar + greeting -->
        <div class="flex items-center gap-5">
            <!-- Avatar ring -->
            <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full bg-white/20 ring-4 ring-white/30 flex items-center justify-center text-2xl font-extrabold text-white shadow-lg select-none">
                    VR
                </div>
                <span class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full bg-emerald-400 ring-2 ring-white shadow"></span>
            </div>
            <!-- Text -->
            <div>
                <p class="text-blue-200 text-xs font-semibold uppercase tracking-widest mb-0.5">Panel de Administración</p>
                <h1 class="text-2xl font-extrabold text-white leading-tight drop-shadow-sm">
                    ¡Bienvenido, Matias! 👋
                </h1>
                <div class="mt-1.5 flex items-center gap-2 text-blue-200 text-sm">
                    <span class="inline-flex items-center gap-1">
                        📅 <span class="font-medium">Viernes, 13 de marzo de 2026</span>
                    </span>
                    <span class="opacity-40">·</span>
                    <span class="inline-flex items-center gap-1">
                        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
                        <span class="text-emerald-300 font-medium">En línea</span>
                    </span>
                </div>
            </div>
        </div>
        <!-- Right: action button + mini stat -->
        <div class="flex flex-col items-end gap-3 flex-shrink-0">
            <a asp-controller="Tickets" asp-action="Create"
               class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white text-blue-700 text-sm font-bold shadow-md hover:bg-blue-50 active:scale-95 transition-all">
                ➕ Nuevo Ticket
            </a>
            <p class="text-blue-200/80 text-xs">
                <span class="font-semibold text-white">38</span> tickets abiertos hoy
            </p>
        </div>
    </div>
</div>

<!-- KPI cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Tickets Abiertos</p>
                <p class="mt-1 text-3xl font-bold text-indigo-600">38</p>
                <p class="mt-1 text-xs text-emerald-600 font-medium">▲ 4 nuevos hoy</p>
            </div>
            <div class="w-10 h-10 rounded-lg bg-indigo-50 flex items-center justify-center text-xl">🎫</div>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Cerrados Hoy</p>
                <p class="mt-1 text-3xl font-bold text-emerald-600">12</p>
                <p class="mt-1 text-xs text-gray-400">Meta diaria: 15</p>
            </div>
            <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center text-xl">✅</div>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Vencidos (SLA)</p>
                <p class="mt-1 text-3xl font-bold text-red-600">5</p>
                <p class="mt-1 text-xs text-red-500 font-medium">Atención requerida</p>
            </div>
            <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center text-xl">⚠️</div>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Sin Asignar</p>
                <p class="mt-1 text-3xl font-bold text-amber-500">7</p>
                <p class="mt-1 text-xs text-amber-600">Pendientes de asignación</p>
            </div>
            <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center text-xl">📥</div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <!-- Tickets recientes -->
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="flex items-center justify-between px-5 py-3.5 border-b border-gray-100">
            <h2 class="text-sm font-semibold text-gray-800">Tickets Recientes</h2>
            <a asp-controller="Tickets" asp-action="Index" class="text-xs text-indigo-600 hover:text-indigo-700 font-medium">Ver todos →</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50 border-b border-gray-100">
                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">#</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Asunto</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Usuario</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Prioridad</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Estado</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <tr class="hover:bg-slate-50/70 transition-colors">
                        <td class="px-4 py-3 text-xs text-gray-400 font-mono">100249</td>
                        <td class="px-4 py-3"><a asp-controller="Tickets" asp-action="Detail" asp-route-id="100249" class="text-indigo-600 hover:text-indigo-800 font-medium">Acceso VPN bloqueado</a><br><span class="text-xs text-gray-400">Soporte Técnico</span></td>
                        <td class="px-4 py-3 text-gray-600">Pedro Soto</td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Urgente</span></td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Abierto</span></td>
                    </tr>
                    <tr class="hover:bg-slate-50/70 transition-colors">
                        <td class="px-4 py-3 text-xs text-gray-400 font-mono">100248</td>
                        <td class="px-4 py-3"><a asp-controller="Tickets" asp-action="Detail" asp-route-id="100248" class="text-indigo-600 hover:text-indigo-800 font-medium">Falla en impresora HP 402</a><br><span class="text-xs text-gray-400">Hardware</span></td>
                        <td class="px-4 py-3 text-gray-600">Ana Torres</td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Baja</span></td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Resuelto</span></td>
                    </tr>
                    <tr class="hover:bg-slate-50/70 transition-colors">
                        <td class="px-4 py-3 text-xs text-gray-400 font-mono">100247</td>
                        <td class="px-4 py-3"><a asp-controller="Tickets" asp-action="Detail" asp-route-id="100247" class="text-indigo-600 hover:text-indigo-800 font-medium">Consulta factura enero 2026</a><br><span class="text-xs text-gray-400">Facturación</span></td>
                        <td class="px-4 py-3 text-gray-600">Carlos López</td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">Normal</span></td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Esperando resp.</span></td>
                    </tr>
                    <tr class="hover:bg-slate-50/70 transition-colors">
                        <td class="px-4 py-3 text-xs text-gray-400 font-mono">100246</td>
                        <td class="px-4 py-3"><a asp-controller="Tickets" asp-action="Detail" asp-route-id="100246" class="text-indigo-600 hover:text-indigo-800 font-medium">Solicitud de laptop nueva</a><br><span class="text-xs text-gray-400">Hardware</span></td>
                        <td class="px-4 py-3 text-gray-600">María González</td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">Normal</span></td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Abierto</span></td>
                    </tr>
                    <tr class="hover:bg-slate-50/70 transition-colors">
                        <td class="px-4 py-3 text-xs text-gray-400 font-mono">100245</td>
                        <td class="px-4 py-3"><a asp-controller="Tickets" asp-action="Detail" asp-route-id="100245" class="text-indigo-600 hover:text-indigo-800 font-medium">Error al iniciar sesión en ERP</a><br><span class="text-xs text-gray-400">Soporte Técnico</span></td>
                        <td class="px-4 py-3 text-gray-600">Juan Pérez</td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-700">Alta</span></td>
                        <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Abierto</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Stats sidebar -->
    <div class="space-y-4">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
            <div class="px-5 py-3.5 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-800">Por Departamento</h2>
            </div>
            <div class="px-5 py-4 space-y-3">
                <div>
                    <div class="flex justify-between text-xs mb-1"><span class="text-gray-600">Soporte Técnico</span><span class="text-gray-400 font-mono">18</span></div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 rounded-full" style="width:47%"></div></div>
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1"><span class="text-gray-600">Hardware</span><span class="text-gray-400 font-mono">11</span></div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full bg-emerald-500 rounded-full" style="width:29%"></div></div>
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1"><span class="text-gray-600">Facturación</span><span class="text-gray-400 font-mono">6</span></div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full bg-amber-400 rounded-full" style="width:16%"></div></div>
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1"><span class="text-gray-600">RRHH</span><span class="text-gray-400 font-mono">3</span></div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full bg-sky-400 rounded-full" style="width:8%"></div></div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
            <div class="px-5 py-3.5 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-800">Carga de Agentes</h2>
            </div>
            <div class="divide-y divide-gray-50">
                <div class="flex items-center justify-between px-5 py-3">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 text-xs font-bold flex items-center justify-center">MR</div>
                        <span class="text-sm text-gray-700">Matias Robles</span>
                    </div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">14</span>
                </div>
                <div class="flex items-center justify-between px-5 py-3">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 text-xs font-bold flex items-center justify-center">DC</div>
                        <span class="text-sm text-gray-700">Diego Castillo</span>
                    </div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">11</span>
                </div>
                <div class="flex items-center justify-between px-5 py-3">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-full bg-amber-100 text-amber-700 text-xs font-bold flex items-center justify-center">MF</div>
                        <span class="text-sm text-gray-700">Matías Fernández</span>
                    </div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">9</span>
                </div>
                <div class="flex items-center justify-between px-5 py-3">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-full bg-gray-100 text-gray-600 text-xs font-bold flex items-center justify-center">SM</div>
                        <span class="text-sm text-gray-700">Sofía Morales</span>
                    </div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">4</span>
                </div>
            </div>
        </div>
    </div>
</div>