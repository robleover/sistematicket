@{
    ViewData["Title"] = "Plugins";
    ViewData["Breadcrumb"] = "6.9 Plugins";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var plugins = new[] {
        new { Id = "ldap",       Name = "LDAP Authentication",    Icon = "🔒", Installed = true,  Active = true,  Category = "Auth",    Version = "1.4.2", Desc = "Autenticación de agentes y usuarios contra un servidor LDAP/Active Directory." },
        new { Id = "oauth2",     Name = "OAuth2 / SSO",           Icon = "🔑", Installed = true,  Active = false, Category = "Auth",    Version = "2.1.0", Desc = "Single Sign-On con proveedores OAuth2 como Google, Azure AD o GitHub." },
        new { Id = "cas",        Name = "CAS Authentication",     Icon = "🎟️", Installed = false, Active = false, Category = "Auth",    Version = "1.0.0", Desc = "Integración con Central Authentication Service (CAS) para SSO universitario." },
        new { Id = "audit",      Name = "Audit Logs",             Icon = "📋", Installed = true,  Active = true,  Category = "Seguridad", Version = "3.0.1", Desc = "Registro detallado de acciones administrativas para auditoría y cumplimiento." },
        new { Id = "s3",         Name = "S3 Storage",             Icon = "☁️", Installed = false, Active = false, Category = "Almacenamiento", Version = "1.2.0", Desc = "Almacenamiento de adjuntos en Amazon S3 o compatible (MinIO, Wasabi)." },
        new { Id = "filesystem", Name = "Filesystem Storage",     Icon = "💾", Installed = true,  Active = true,  Category = "Almacenamiento", Version = "1.0.0", Desc = "Almacenamiento local de adjuntos en el sistema de archivos del servidor." },
        new { Id = "phar",       Name = "Phar Plugins",           Icon = "📦", Installed = false, Active = false, Category = "Core",    Version = "1.0.0", Desc = "Soporte para instalación de plugins empaquetados en formato .phar." },
    };
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-xl font-bold text-gray-900">🔌 Plugins</h1>
        <p class="text-sm text-gray-500 mt-0.5">Admin Panel › Manage › Plugins</p>
    </div>
    <button class="btn-secondary btn-sm">📦 Instalar desde archivo</button>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-6">
    @foreach (var p in plugins)
    {
        <div class="card p-4 flex flex-col gap-3 @(!p.Installed ? "opacity-70" : "")">
            <div class="flex items-start justify-between">
                <div class="flex items-center gap-2.5">
                    <span class="text-2xl">@p.Icon</span>
                    <div>
                        <p class="text-sm font-semibold text-gray-800 leading-tight">@p.Name</p>
                        <p class="text-xs text-gray-400">v@p.Version · @p.Category</p>
                    </div>
                </div>
                @if (!p.Installed)
                {
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">No instalado</span>
                }
                else if (p.Active)
                {
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activo</span>
                }
                else
                {
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inactivo</span>
                }
            </div>
            <p class="text-xs text-gray-500 leading-relaxed flex-1">@p.Desc</p>
            <div class="flex gap-1.5 pt-1 border-t border-gray-50">
                @if (!p.Installed)
                {
                    <button class="btn-primary btn-sm flex-1">Instalar</button>
                }
                else
                {
                    @if (p.Active)
                    {
                        <button class="btn-sm flex-1 px-2 py-1.5 text-xs rounded-lg bg-amber-50 text-amber-700 border border-amber-200 hover:bg-amber-100">Desactivar</button>
                    }
                    else
                    {
                        <button class="btn-sm flex-1 px-2 py-1.5 text-xs rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-200 hover:bg-emerald-100">Activar</button>
                    }
                    @if (p.Id == "ldap")
                    {
                        <button onclick="document.getElementById('ldap-config').scrollIntoView({behavior:'smooth'})" class="btn-sm px-2 py-1.5 text-xs rounded-lg bg-slate-100 text-slate-600 border border-slate-200 hover:bg-slate-200">Configurar</button>
                    }
                    else
                    {
                        <button class="btn-sm px-2 py-1.5 text-xs rounded-lg bg-slate-100 text-slate-600 border border-slate-200 hover:bg-slate-200">Configurar</button>
                    }
                    <button class="btn-sm px-2 py-1.5 text-xs rounded-lg bg-red-50 text-red-600 border border-red-200 hover:bg-red-100">Desinstalar</button>
                }
            </div>
        </div>
    }
</div>

<!-- LDAP Config -->
<div id="ldap-config" class="card p-5">
    <div class="flex items-center gap-2 mb-5">
        <span class="text-xl">🔒</span>
        <div>
            <h2 class="text-base font-semibold text-gray-800">Configuración LDAP</h2>
            <p class="text-xs text-gray-500 mt-0.5">LDAP Authentication · v1.4.2</p>
        </div>
        <span class="ml-auto inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Activo</span>
    </div>

    <div class="space-y-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Conexión al servidor</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div class="md:col-span-2">
                <label class="form-label">Servidor LDAP <span class="text-red-500">*</span></label>
                <input type="text" class="form-input" placeholder="ldap.empresa.cl" value="ldap.empresa.cl" />
            </div>
            <div>
                <label class="form-label">Puerto</label>
                <input type="number" class="form-input" placeholder="389" value="389" />
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div class="md:col-span-2">
                <label class="form-label">Search Base DN</label>
                <input type="text" class="form-input" placeholder="dc=empresa,dc=cl" value="dc=empresa,dc=cl" />
            </div>
            <div>
                <label class="form-label">Dominio</label>
                <input type="text" class="form-input" placeholder="empresa.cl" value="empresa.cl" />
            </div>
        </div>
        <div>
            <label class="form-label">Bind DN (cuenta de servicio)</label>
            <input type="text" class="form-input" placeholder="cn=servicio,ou=cuentas,dc=empresa,dc=cl" value="cn=servicio,ou=cuentas,dc=empresa,dc=cl" />
        </div>

        <div class="pt-2 border-t border-gray-100">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Mapeo de atributos</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div>
                    <label class="form-label">Atributo Email</label>
                    <input type="text" class="form-input" value="mail" />
                </div>
                <div>
                    <label class="form-label">Atributo Nombre</label>
                    <input type="text" class="form-input" value="cn" />
                </div>
                <div>
                    <label class="form-label">Atributo Teléfono</label>
                    <input type="text" class="form-input" value="telephoneNumber" />
                </div>
            </div>
        </div>

        <div class="flex items-center gap-2 pt-2">
            <input type="checkbox" id="ldap-autocreate" checked class="w-4 h-4 rounded accent-indigo-600" />
            <label for="ldap-autocreate" class="text-sm text-gray-700">Crear usuario automáticamente al primer inicio de sesión</label>
        </div>

        <div class="flex gap-2 pt-3 border-t border-gray-100">
            <button class="btn-primary btn-sm">💾 Guardar configuración</button>
            <button class="btn-secondary btn-sm">🔗 Probar conexión</button>
        </div>
    </div>
</div>
