@{
    ViewData["Title"] = "Roles y Permisos";
    ViewData["Breadcrumb"] = "Roles y Permisos";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- Page Banner -->
<div class="relative mb-6 rounded-2xl overflow-hidden shadow-lg" style="background-image: url('/img/fondo1.png'); background-size: cover; background-position: center;">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(29,78,216,0.82) 0%, rgba(37,99,235,0.78) 45%, rgba(14,165,233,0.72) 100%);"></div>
    <div class="absolute inset-0 opacity-5" style="background-image:repeating-linear-gradient(0deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px),repeating-linear-gradient(90deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px);"></div>
    <div class="relative z-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 px-7 py-5">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-white/20 ring-2 ring-white/30 flex items-center justify-center text-2xl shadow-inner select-none">🔑</div>
            <div>
                <p class="text-blue-200 text-xs font-semibold uppercase tracking-widest mb-0.5">Admin Panel › Organización</p>
                <h1 class="text-xl font-extrabold text-white leading-tight drop-shadow-sm">Roles y Permisos</h1>
                <p class="text-blue-200/80 text-xs mt-0.5">Control de acceso basado en roles</p>
            </div>
        </div>
        <button class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white text-blue-700 text-sm font-bold shadow-md hover:bg-blue-50 active:scale-95 transition-all flex-shrink-0">➕ Nuevo rol</button>
    </div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    @{
        var roles = new[] {
            new { Name="Acceso Total", Emoji="👑", Color="bg-purple-50 border-purple-200", Badge="bg-purple-100 text-purple-700", Perms=new[]{"Tickets: Total","Tareas: Total","KB: Total","Config: ✓","Agentes: ✓"} },
            new { Name="Expandido", Emoji="🔓", Color="bg-blue-50 border-blue-200", Badge="bg-blue-100 text-blue-700", Perms=new[]{"Tickets: Total","Tareas: Total","KB: Editar","Config: ✗","Agentes: ✗"} },
            new { Name="Limitado", Emoji="🔒", Color="bg-sky-50 border-sky-200", Badge="bg-sky-100 text-sky-700", Perms=new[]{"Tickets: Asignados","Tareas: Ver","KB: Ver","Config: ✗","Agentes: ✗"} },
            new { Name="Solo lectura", Emoji="👁️", Color="bg-gray-50 border-gray-200", Badge="bg-gray-100 text-gray-600", Perms=new[]{"Tickets: Ver","Tareas: Ver","KB: Ver","Config: ✗","Agentes: ✗"} },
            new { Name="Colaborador", Emoji="✏️", Color="bg-emerald-50 border-emerald-200", Badge="bg-emerald-100 text-emerald-700", Perms=new[]{"Tickets: Comentar","Tareas: Ver","KB: Publicar","Config: ✗","Agentes: ✗"} },
        };
    }
    @foreach (var role in roles) {
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl">@role.Emoji</span>
            <h3 class="font-semibold text-gray-800">@role.Name</h3>
        </div>
        <div class="flex flex-wrap gap-1.5 mb-4">
            @foreach(var p in role.Perms) {
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium @role.Badge border border-transparent">@p</span>
            }
        </div>
        <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
            <button class="text-xs text-indigo-600 hover:underline">Editar</button>
            <button class="text-xs text-red-500 hover:underline">Eliminar</button>
        </div>
    </div>
    }
</div>
