@{
    ViewData["Title"] = "Equipos";
    ViewData["Breadcrumb"] = "6.5 Equipos";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-xl font-bold text-gray-900">👥 Equipos</h1>
        <p class="text-sm text-gray-500 mt-0.5">Admin Panel › Agents › Teams</p>
    </div>
    <button onclick="document.getElementById('modalNewTeam').classList.remove('hidden')" class="btn-primary btn-sm">+ Nuevo Equipo</button>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="card p-5">
        <div class="flex items-start justify-between mb-3">
            <div>
                <h2 class="font-semibold text-gray-800">Equipo VIP</h2>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 mt-1">Activo</span>
            </div>
            <button class="text-gray-400 hover:text-indigo-600 transition-colors text-sm">✏️</button>
        </div>
        <div class="text-xs text-gray-500 mb-3">
            <span class="font-medium text-gray-600">Líder:</span>
            <div class="flex items-center gap-2 mt-1">
                <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold">VR</div>
                <span>Valentina Ruiz</span>
            </div>
        </div>
        <div class="text-xs text-gray-500 mb-3">
            <span class="font-medium text-gray-600">Miembros:</span>
            <div class="flex gap-1 mt-1 flex-wrap">
                <div class="w-6 h-6 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-xs font-bold" title="Matías Fernández">MF</div>
                <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold" title="Sofía Morales">SM</div>
                <div class="w-6 h-6 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold" title="Diego Castillo">DC</div>
            </div>
        </div>
        <div class="flex items-center justify-between pt-3 border-t border-gray-100">
            <span class="text-xs text-gray-400">Tickets activos</span>
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">7</span>
        </div>
    </div>

    <div class="card p-5">
        <div class="flex items-start justify-between mb-3">
            <div>
                <h2 class="font-semibold text-gray-800">Hardware Nivel 2</h2>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 mt-1">Activo</span>
            </div>
            <button class="text-gray-400 hover:text-indigo-600 transition-colors text-sm">✏️</button>
        </div>
        <div class="text-xs text-gray-500 mb-3">
            <span class="font-medium text-gray-600">Líder:</span>
            <div class="flex items-center gap-2 mt-1">
                <div class="w-6 h-6 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-xs font-bold">MF</div>
                <span>Matías Fernández</span>
            </div>
        </div>
        <div class="text-xs text-gray-500 mb-3">
            <span class="font-medium text-gray-600">Miembros:</span>
            <div class="flex gap-1 mt-1 flex-wrap">
                <div class="w-6 h-6 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold" title="Diego Castillo">DC</div>
                <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold" title="Valentina Ruiz">VR</div>
            </div>
        </div>
        <div class="flex items-center justify-between pt-3 border-t border-gray-100">
            <span class="text-xs text-gray-400">Tickets activos</span>
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">4</span>
        </div>
    </div>

    <div class="card p-5 opacity-70">
        <div class="flex items-start justify-between mb-3">
            <div>
                <h2 class="font-semibold text-gray-800">Guardia Nocturna</h2>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 mt-1">Inactivo</span>
            </div>
            <button class="text-gray-400 hover:text-indigo-600 transition-colors text-sm">✏️</button>
        </div>
        <div class="text-xs text-gray-500 mb-3">
            <span class="font-medium text-gray-600">Líder:</span>
            <p class="mt-1 text-gray-400">Sin asignar</p>
        </div>
        <div class="text-xs text-gray-500 mb-3">
            <span class="font-medium text-gray-600">Miembros:</span>
            <p class="mt-1 text-gray-400">Sin miembros</p>
        </div>
        <div class="flex items-center justify-between pt-3 border-t border-gray-100">
            <span class="text-xs text-gray-400">Tickets activos</span>
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">0</span>
        </div>
    </div>
</div>

<div class="flex items-start gap-2 bg-sky-50 border border-sky-200 rounded-xl px-4 py-3 text-sm text-sky-800">
    <span class="mt-0.5">ℹ️</span>
    <span>Los equipos se asignan automáticamente según las reglas definidas en los temas de ayuda. Un agente puede pertenecer a múltiples equipos.</span>
</div>

<div id="modalNewTeam" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h3 class="text-base font-semibold">Nuevo Equipo</h3>
            <button onclick="document.getElementById('modalNewTeam').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
        </div>
        <div class="p-5 space-y-3">
            <div>
                <label class="form-label">Nombre del equipo <span class="text-red-500">*</span></label>
                <input type="text" class="form-input" placeholder="ej. Equipo VIP" />
            </div>
            <div>
                <label class="form-label">Líder</label>
                <select class="form-select">
                    <option>— Sin líder —</option>
                    <option>Valentina Ruiz</option>
                    <option>Matías Fernández</option>
                    <option>Sofía Morales</option>
                    <option>Diego Castillo</option>
                </select>
            </div>
            <div>
                <label class="form-label">Miembros</label>
                <div class="space-y-2 bg-slate-50 rounded-lg p-3">
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input type="checkbox" class="rounded border-gray-300 text-indigo-600" />
                        Valentina Ruiz
                    </label>
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input type="checkbox" class="rounded border-gray-300 text-indigo-600" />
                        Matías Fernández
                    </label>
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input type="checkbox" class="rounded border-gray-300 text-indigo-600" />
                        Sofía Morales
                    </label>
                    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                        <input type="checkbox" class="rounded border-gray-300 text-indigo-600" />
                        Diego Castillo
                    </label>
                </div>
            </div>
        </div>
        <div class="flex justify-end gap-2 px-5 py-4 border-t border-gray-100">
            <button onclick="document.getElementById('modalNewTeam').classList.add('hidden')" class="btn-secondary btn-sm">Cancelar</button>
            <button class="btn-primary btn-sm">Guardar Equipo</button>
        </div>
    </div>
</div>
