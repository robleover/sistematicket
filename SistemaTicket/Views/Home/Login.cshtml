@{
    Layout = null;
    var loginError = ViewData["LoginError"] as string;
    var savedUser = ViewData["Username"] as string ?? "";
    var returnUrl = ViewData["ReturnUrl"] as string ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesion — SistemaTicket</title>
    <link rel="preload" href="/img/f1.mp4" as="video" type="video/mp4" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: { brand: { DEFAULT: '#6366f1', dark: '#4f46e5' } } } }
        }
    </script>
</head>
<body class="min-h-screen bg-purple-100 flex flex-col">

    <!-- Topbar -->
    <header class="bg-[#1e1b4b] text-white shadow">
        <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
                <span class="text-2xl">🎫</span>
                <span class="font-bold text-lg tracking-tight">SistemaTicket</span>
            </a>
            <a href="/" class="text-sm text-indigo-200 hover:text-white transition-colors">← Volver al portal</a>
        </div>
    </header>

    <!-- Contenido -->
    <main class="relative flex-1 flex items-center justify-center px-4 py-12 overflow-hidden">
        <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover">
            <source src="/img/f1.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-indigo-900/60"></div>
        <div class="relative z-10 w-full max-w-md">

            <!-- Tabs -->
            <div class="flex rounded-xl overflow-hidden border border-white/35 mb-6 bg-white/25 backdrop-blur shadow-sm">
                <button id="tabLogin" onclick="switchTab('login')"
                    class="flex-1 py-3 text-sm font-semibold text-white bg-white/40 transition-colors">
                    Iniciar sesion
                </button>
                <button id="tabRegister" onclick="switchTab('register')"
                    class="flex-1 py-3 text-sm font-semibold text-white/80 hover:bg-white/30 transition-colors">
                    Registrarse
                </button>
            </div>

            <!-- Panel Login -->
            <div id="panelLogin" class="bg-white/25 backdrop-blur-xl rounded-2xl shadow-xl border border-white/35 p-8">
                <h2 class="text-lg font-bold text-white mb-1">Bienvenido de vuelta</h2>
                <p class="text-sm text-white/70 mb-6">Ingresa con tu cuenta para continuar</p>

                @if (!string.IsNullOrEmpty(loginError))
                {
                    <div class="flex items-center gap-2 bg-red-500/20 border border-red-400/40 rounded-xl px-4 py-3 mb-5">
                        <span class="text-red-300 text-lg flex-shrink-0">⚠️</span>
                        <span class="text-sm text-red-200">@loginError</span>
                    </div>
                }

                <form method="post" action="/Home/Login">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-semibold text-white/90 mb-1.5">Usuario o correo electronico</label>
                            <input type="text" name="username" value="@savedUser" placeholder="demo"
                                autocomplete="username"
                                class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60 transition-shadow" />
                        </div>
                        <div>
                            <div class="flex items-center justify-between mb-1.5">
                                <label class="block text-xs font-semibold text-white/90">Contrasena</label>
                                <a href="#" class="text-xs text-white/70 hover:text-white transition-colors">Olvide mi contrasena</a>
                            </div>
                            <input type="password" name="password" placeholder="••••••••"
                                autocomplete="current-password"
                                class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60 transition-shadow" />
                        </div>
                        <label class="flex items-center gap-2 text-sm text-white/80 cursor-pointer">
                            <input type="checkbox" class="rounded" />
                            Recordarme
                        </label>
                        <button type="submit"
                            class="w-full py-3 rounded-xl bg-white/35 hover:bg-white/45 text-white font-semibold text-sm transition-colors border border-white/40 shadow">
                            Iniciar sesion →
                        </button>
                    </div>
                </form>

                <!-- Demo hint -->
                <div class="mt-6 bg-white/20 border border-white/35 rounded-xl p-4">
                    <p class="text-xs font-semibold text-white mb-2">🔑 Acceso de demostracion</p>
                    <div class="grid grid-cols-2 gap-2 text-xs">
                        <div class="bg-white/25 rounded-lg border border-white/35 px-3 py-2">
                            <span class="text-white/70 block">Usuario</span>
                            <span class="font-mono font-bold text-white">demo</span>
                        </div>
                        <div class="bg-white/25 rounded-lg border border-white/35 px-3 py-2">
                            <span class="text-white/70 block">Contrasena</span>
                            <span class="font-mono font-bold text-white">demo</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Panel Registro -->
            <div id="panelRegister" class="hidden bg-white/25 backdrop-blur-xl rounded-2xl shadow-xl border border-white/35 p-8">
                <h2 class="text-lg font-bold text-white mb-1">Crear una cuenta</h2>
                <p class="text-sm text-white/70 mb-6">Registrate para hacer seguimiento de tus tickets</p>
                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-semibold text-white/90 mb-1.5">Nombre</label>
                            <input type="text" placeholder="Juan" class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-white/90 mb-1.5">Apellido</label>
                            <input type="text" placeholder="Perez" class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-white/90 mb-1.5">Correo electronico</label>
                        <input type="email" placeholder="juan@empresa.com" class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-white/90 mb-1.5">Contrasena</label>
                        <input type="password" placeholder="••••••••" class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-white/90 mb-1.5">Confirmar contrasena</label>
                        <input type="password" placeholder="••••••••" class="w-full rounded-xl border border-white/40 bg-white/30 px-4 py-3 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/60" />
                    </div>
                    <button type="button" class="w-full py-3 rounded-xl bg-white/35 hover:bg-white/45 text-white font-semibold text-sm transition-colors border border-white/40 shadow">
                        Crear cuenta
                    </button>
                    <p class="text-xs text-center text-white/50">
                        Solo para demo — el registro no persiste datos
                    </p>
                </div>
            </div>

        </div>
    </main>

    <footer class="bg-[#1e1b4b] text-indigo-300 text-xs text-center py-4">
        © 2026 SistemaTicket — Todos los derechos reservados
    </footer>

    <script>
        function switchTab(tab) {
            var l = document.getElementById('panelLogin');
            var r = document.getElementById('panelRegister');
            var tL = document.getElementById('tabLogin');
            var tR = document.getElementById('tabRegister');
            if (tab === 'login') {
                l.classList.remove('hidden'); r.classList.add('hidden');
                tL.className = 'flex-1 py-3 text-sm font-semibold text-white bg-white/40 transition-colors';
                tR.className = 'flex-1 py-3 text-sm font-semibold text-white/80 hover:bg-white/30 transition-colors';
            } else {
                r.classList.remove('hidden'); l.classList.add('hidden');
                tR.className = 'flex-1 py-3 text-sm font-semibold text-white bg-white/40 transition-colors';
                tL.className = 'flex-1 py-3 text-sm font-semibold text-white/80 hover:bg-white/30 transition-colors';
            }
        }
    </script>
</body>
</html>
