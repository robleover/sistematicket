@{
    ViewData["Title"] = "Ticket #100248";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Modal reapertura -->
<div id="modalReopen" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">🔄 Solicitar Reapertura</h3>
        <p class="text-xs text-gray-500 mb-3">Si el problema que reportaste no fue resuelto, puedes solicitar la reapertura del ticket.</p>
        <div><label class="block text-xs font-medium text-gray-600 mb-1">Motivo de la reapertura</label><textarea rows="3" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Explica por qué necesitas reabrir este ticket..."></textarea></div>
        <div class="flex justify-end gap-2 mt-4"><button onclick="document.getElementById('modalReopen').classList.add('hidden')" class="px-3 py-2 text-sm border border-gray-200 rounded-lg hover:bg-gray-50">Cancelar</button><button class="px-4 py-2 text-sm bg-amber-500 text-white rounded-lg hover:bg-amber-600">🔄 Solicitar Reapertura</button></div>
    </div>
</div>

<!-- Page Banner -->
<div class="relative mb-6 rounded-2xl overflow-hidden shadow-lg" style="background-image: url('/img/fondo2.png'); background-size: cover; background-position: center;">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(29,78,216,0.82) 0%, rgba(37,99,235,0.78) 45%, rgba(14,165,233,0.72) 100%);"></div>
    <div class="absolute -top-10 -right-10 w-52 h-52 rounded-full opacity-20" style="background:radial-gradient(circle, #bfdbfe, transparent 70%);"></div>
    <div class="absolute bottom-0 left-1/3 w-72 h-24 rounded-full opacity-10" style="background:radial-gradient(ellipse, #fff, transparent 70%);"></div>
    <div class="absolute top-0 left-0 w-40 h-40 rounded-full opacity-10" style="background:radial-gradient(circle, #60a5fa, transparent 70%);"></div>
    <div class="absolute inset-0 opacity-5" style="background-image:repeating-linear-gradient(0deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px),repeating-linear-gradient(90deg,transparent,transparent 30px,rgba(255,255,255,.6) 30px,rgba(255,255,255,.6) 31px);"></div>
    <div class="relative z-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 px-7 py-5">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-white/20 ring-2 ring-white/30 flex items-center justify-center text-2xl shadow-inner select-none">🎫</div>
            <div>
                <div class="flex items-center gap-2 mb-1">
                    <a asp-controller="Portal" asp-action="MyTickets" class="text-blue-300 hover:text-white text-xs transition-colors">← Mis Tickets</a>
                    <span class="text-blue-400/50">/</span>
                    <span class="text-blue-200 text-xs font-medium">#100248</span>
                </div>
                <h1 class="text-xl font-extrabold text-white leading-tight drop-shadow-sm">No puedo acceder al sistema desde ayer</h1>
                <div class="flex flex-wrap items-center gap-2 mt-1.5">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-400/30 text-red-100 ring-1 ring-red-300/40">Abierto</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-500/30 text-red-100 ring-1 ring-red-400/40">🔴 Urgente</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-white/10 text-blue-100">Soporte Técnico</span>
                    <span class="text-xs text-blue-200">• Abierto el 15 ene 2025 09:15</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-3 gap-5">
    <!-- Conversación -->
    <div class="col-span-2 space-y-4">
        <div class="space-y-3">
            <!-- Mensaje original del cliente -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
                <div class="flex items-start gap-3 mb-3">
                    <div class="w-8 h-8 rounded-full bg-sky-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">PS</div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between"><span class="text-sm font-semibold text-gray-800">Pedro Soto</span><span class="text-xs text-gray-400">15 ene 2025, 09:15</span></div>
                        <div class="text-xs text-gray-400">pedro.soto@@empresa.cl <span class="text-sky-500 font-medium">(Tú)</span></div>
                    </div>
                </div>
                <div class="text-sm text-gray-700 pl-11">
                    Hola, desde ayer por la mañana no puedo ingresar al sistema de gestión. Aparece el siguiente error:
                    <div class="my-2 p-3 rounded-lg bg-gray-50 border border-gray-200 font-mono text-xs text-gray-600">Error: "Authentication failed — token expired or invalid. Contact your administrator."</div>
                    El problema ocurre en Chrome y en Edge. Ya probé cerrar sesión y volver a entrar pero el error persiste.
                </div>
            </div>

            <!-- Respuesta del agente -->
            <div class="bg-indigo-50 rounded-xl border border-indigo-100 p-5">
                <div class="flex items-start gap-3 mb-3">
                    <div class="w-8 h-8 rounded-full bg-indigo-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">VR</div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between"><span class="text-sm font-semibold text-gray-800">Matias Robles</span><span class="text-xs text-gray-400">15 ene 2025, 10:42</span></div>
                        <div class="text-xs text-gray-400">Agente → Cliente</div>
                    </div>
                </div>
                <div class="text-sm text-gray-700 pl-11">
                    <p class="mb-2">Estimado Pedro,</p>
                    <p class="mb-2">Gracias por contactarnos. He revisado tu cuenta y efectivamente el token de sesión expiró de forma forzada por un reinicio de seguridad que realizamos en el servidor.</p>
                    <p class="mb-2">Por favor haz lo siguiente:</p>
                    <ol class="list-decimal list-inside space-y-1 mb-2">
                        <li>Abre el navegador en modo incógnito (Ctrl + Shift + N)</li>
                        <li>Dirígete a <strong>sistema.empresa.cl/login</strong></li>
                        <li>Ingresa tu usuario y contraseña habitual</li>
                        <li>Si solicita un código de verificación, revisa tu email con el código de 6 dígitos</li>
                    </ol>
                    <p>Avísame si el problema persiste y generaremos un nuevo token manualmente desde el panel de administración.</p>
                    <p class="text-gray-400 text-xs mt-2">Matias Robles — Soporte Técnico</p>
                </div>
            </div>

            <!-- Segunda respuesta del cliente -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
                <div class="flex items-start gap-3 mb-3">
                    <div class="w-8 h-8 rounded-full bg-sky-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">PS</div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between"><span class="text-sm font-semibold text-gray-800">Pedro Soto</span><span class="text-xs text-gray-400">15 ene 2025, 11:05</span></div>
                        <div class="text-xs text-gray-400">pedro.soto@@empresa.cl <span class="text-sky-500 font-medium">(Tú)</span></div>
                    </div>
                </div>
                <div class="text-sm text-gray-700 pl-11">Seguí los pasos pero en el paso 4 no me llegó ningún código al email. Esperé 10 minutos y revisé el spam también. El acceso sigue bloqueado.</div>
            </div>

            <!-- Aviso de espera -->
            <div class="flex items-center gap-2 px-4 py-3 bg-blue-50 border border-blue-100 rounded-xl text-sm text-blue-700">
                <span>⏳</span>
                <span>El agente ha sido notificado de tu última respuesta y trabajará en una solución. Te responderemos pronto.</span>
            </div>
        </div>

        <!-- Panel de respuesta del cliente -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">💬 Añadir Respuesta</h3>
            <textarea rows="5" placeholder="Escribe aquí tu respuesta o cualquier información adicional que pueda ayudar a resolver el problema..." class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 mb-3"></textarea>
            <div class="mb-3">
                <label class="block text-xs font-medium text-gray-600 mb-1">Adjuntar archivos</label>
                <input type="file" multiple class="block w-full text-xs text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100" />
                <p class="text-xs text-gray-400 mt-1">Capturas de pantalla, logs, etc. Máx. 20 MB por archivo</p>
            </div>
            <div class="flex items-center justify-between">
                <label class="flex items-center gap-1.5 text-xs text-gray-500"><input type="checkbox" class="rounded text-indigo-600" /> Marcar como resuelto (el problema fue solucionado)</label>
                <button class="text-xs px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium">📨 Enviar Respuesta</button>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
        <!-- Información del ticket -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Información del Ticket</h3>
            <div class="space-y-3 text-xs">
                <div class="flex justify-between"><span class="text-gray-400">Número</span><span class="font-semibold text-gray-700">#100248</span></div>
                <div class="flex justify-between items-center"><span class="text-gray-400">Estado</span><span class="px-2 py-0.5 rounded-full bg-red-100 text-red-600 font-medium">Abierto</span></div>
                <div class="flex justify-between items-center"><span class="text-gray-400">Prioridad</span><span class="px-2 py-0.5 rounded-full bg-red-50 text-red-600 border border-red-200 font-medium">🔴 Urgente</span></div>
                <div class="flex justify-between"><span class="text-gray-400">Departamento</span><span class="text-gray-700">Soporte Técnico</span></div>
                <div class="flex justify-between"><span class="text-gray-400">Tipo</span><span class="text-gray-700">Acceso / Login</span></div>
                <div class="flex justify-between"><span class="text-gray-400">Creado</span><span class="text-gray-700">15 ene 2025, 09:15</span></div>
                <div class="flex justify-between"><span class="text-gray-400">Actualizado</span><span class="text-gray-700">hace 1 hora</span></div>
                <div class="pt-1 border-t border-gray-100"><span class="text-gray-400">SLA</span><p class="text-green-600 font-medium mt-0.5">✔ Respondido en 1h 27min</p></div>
            </div>
        </div>

        <!-- Agente asignado -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Agente Asignado</h3>
            <div class="flex items-center gap-2">
                <div class="w-9 h-9 rounded-full bg-indigo-500 text-white text-sm font-bold flex items-center justify-center flex-shrink-0">VR</div>
                <div>
                    <div class="text-sm font-medium text-gray-800">Matias Robles</div>
                    <div class="text-xs text-gray-400">Soporte Técnico — Nivel 1</div>
                </div>
            </div>
        </div>

        <!-- Acciones -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Acciones</h3>
            <div class="space-y-2">
                <button class="w-full text-xs px-3 py-2 bg-green-50 text-green-700 border border-green-200 rounded-lg hover:bg-green-100 font-medium text-left">✅ Marcar como Resuelto</button>
                <button onclick="document.getElementById('modalReopen').classList.remove('hidden')" class="w-full text-xs px-3 py-2 bg-amber-50 text-amber-700 border border-amber-200 rounded-lg hover:bg-amber-100 font-medium text-left">🔄 Solicitar Reapertura</button>
                <a asp-controller="Portal" asp-action="NewTicket" class="block w-full text-xs px-3 py-2 bg-indigo-50 text-indigo-700 border border-indigo-200 rounded-lg hover:bg-indigo-100 font-medium text-center">➕ Abrir Nuevo Ticket</a>
                <a asp-controller="Portal" asp-action="MyTickets" class="block w-full text-xs px-3 py-2 text-gray-400 hover:text-gray-600 text-center">← Volver a Mis Tickets</a>
            </div>
        </div>

        <!-- Calificación -->
        <div class="bg-white rounded-xl shadow-sm border border-indigo-100 p-5">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Califica el servicio</h3>
            <p class="text-xs text-gray-400 mb-3">Una vez cerrado el ticket podrás calificar la atención recibida.</p>
            <div class="flex justify-center gap-3 text-2xl">
                <span role="button" title="Muy insatisfecho" class="cursor-pointer hover:scale-125 transition-transform">😠</span>
                <span role="button" title="Insatisfecho" class="cursor-pointer hover:scale-125 transition-transform">😕</span>
                <span role="button" title="Neutral" class="cursor-pointer hover:scale-125 transition-transform">😐</span>
                <span role="button" title="Satisfecho" class="cursor-pointer hover:scale-125 transition-transform">😊</span>
                <span role="button" title="Muy satisfecho" class="cursor-pointer hover:scale-125 transition-transform">😄</span>
            </div>
        </div>
    </div>
</div>
