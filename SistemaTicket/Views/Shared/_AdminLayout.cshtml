@{
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    string NavCls(string action, string ctrl = "Admin")
        => (currentAction == action && currentController == ctrl)
            ? "flex items-center gap-2.5 px-4 py-2 text-sm rounded-lg bg-indigo-500/20 text-indigo-200 font-medium border-l-2 border-indigo-400 mx-2"
            : "flex items-center gap-2.5 px-4 py-2 text-sm rounded-lg text-slate-300 hover:bg-white/5 hover:text-white transition-colors border-l-2 border-transparent mx-2";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin | SistemaTicket</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { DEFAULT: '#6366f1', dark: '#4f46e5', light: '#818cf8' },
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        html, body { height: 100%; margin: 0; }
        @@layer components {
            .btn-primary { @@apply inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition-colors; }
            .btn-secondary { @@apply inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-gray-200 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors; }
            .btn-danger { @@apply inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors; }
            .btn-sm { @@apply px-3 py-1.5 text-xs; }
            .card { @@apply bg-white rounded-xl shadow-sm border border-gray-100; }
            .badge-open { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700; }
            .badge-closed { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600; }
            .badge-urgent { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700; }
            .badge-high { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-700; }
            .badge-normal { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700; }
            .badge-low { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700; }
            .badge-waiting { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700; }
            .badge-resolved { @@apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700; }
            .form-input { @@apply w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 transition; }
            .form-select { @@apply w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 transition bg-white; }
            .form-label { @@apply block text-xs font-semibold text-gray-600 mb-1; }
            .table-th { @@apply px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide; }
            .table-td { @@apply px-4 py-3 text-sm text-gray-700; }
        }
    </style>
</head>
<body class="bg-slate-50 text-gray-800 antialiased">
<div class="flex h-screen overflow-hidden">

    <!-- ── SIDEBAR ── -->
    <aside class="w-64 min-w-[256px] bg-[#1e1b4b] flex flex-col overflow-y-auto shadow-xl">
        <!-- Brand -->
        <div class="px-5 py-4 border-b border-white/10">
            <div class="flex items-center gap-2">
                <span class="text-indigo-300 text-2xl">🎫</span>
                <div>
                    <p class="text-white font-bold text-sm tracking-tight leading-none">SistemaTicket</p>
                    <p class="text-indigo-400 text-xs mt-0.5">Panel de Administración</p>
                </div>
            </div>
        </div>

        <nav class="flex-1 py-3 space-y-0.5">
            <a asp-controller="Admin" asp-action="Index" class="@NavCls("Index")">
                <span>📊</span> Dashboard
            </a>

            <p class="px-6 pt-4 pb-1 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Configuración</p>
            <a asp-controller="Admin" asp-action="SystemSettings" class="@NavCls("SystemSettings")"><span>⚙️</span> Ajustes del sistema</a>
            <a asp-controller="Admin" asp-action="Email" class="@NavCls("Email")"><span>📧</span> Correo electrónico</a>
            <a asp-controller="Admin" asp-action="Forms" class="@NavCls("Forms")"><span>📋</span> Formularios</a>

            <p class="px-6 pt-4 pb-1 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Organización</p>
            <a asp-controller="Admin" asp-action="Departments" class="@NavCls("Departments")"><span>🏢</span> Departamentos</a>
            <a asp-controller="Admin" asp-action="Teams" class="@NavCls("Teams")"><span>👥</span> Equipos</a>
            <a asp-controller="Admin" asp-action="Agents" class="@NavCls("Agents")"><span>👤</span> Agentes</a>
            <a asp-controller="Admin" asp-action="Roles" class="@NavCls("Roles")"><span>🔑</span> Roles y permisos</a>

            <p class="px-6 pt-4 pb-1 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Flujo de trabajo</p>
            <a asp-controller="Admin" asp-action="HelpTopics" class="@NavCls("HelpTopics")"><span>❓</span> Temas de ayuda</a>
            <a asp-controller="Admin" asp-action="SLAPlans" class="@NavCls("SLAPlans")"><span>⏱️</span> SLA</a>
            <a asp-controller="Admin" asp-action="Schedules" class="@NavCls("Schedules")"><span>📅</span> Horarios</a>

            <p class="px-6 pt-4 pb-1 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Sistema</p>
            <a asp-controller="Admin" asp-action="Plugins" class="@NavCls("Plugins")"><span>🔌</span> Plugins</a>

            <div class="mx-4 my-3 border-t border-white/10"></div>
            <a asp-controller="Tickets" asp-action="Index" class="flex items-center gap-2.5 px-4 py-2 text-sm rounded-lg text-slate-400 hover:bg-white/5 hover:text-white transition-colors mx-2"><span>🎫</span> Gestión de Tickets</a>
            <a asp-controller="Portal" asp-action="Index" class="flex items-center gap-2.5 px-4 py-2 text-sm rounded-lg text-slate-400 hover:bg-white/5 hover:text-white transition-colors mx-2"><span>🏠</span> Portal de Clientes</a>
        </nav>

        <!-- User card -->
        <div class="px-4 py-3 border-t border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-indigo-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">VR</div>
                <div class="min-w-0">
                    <p class="text-sm text-white font-medium leading-none truncate">Valentina Ruiz</p>
                    <p class="text-xs text-indigo-300 mt-0.5">Administrador</p>
                </div>
                <span class="ml-auto w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
            </div>
        </div>
    </aside>

    <!-- ── MAIN ── -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Topbar -->
        <div class="flex-shrink-0 bg-white border-b border-gray-100 px-6 h-14 flex items-center justify-between shadow-sm">
            <nav class="flex items-center gap-2 text-sm">
                <a asp-controller="Admin" asp-action="Index" class="text-indigo-600 hover:text-indigo-800 font-medium">Admin</a>
                @if (ViewData["Breadcrumb"] != null)
                {
                    <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-gray-500">@ViewData["Breadcrumb"]</span>
                }
            </nav>
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-1 text-xs text-emerald-600 font-medium">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span> En línea
                </span>
                <a asp-controller="Home" asp-action="Index" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">← Salir al sitio</a>
            </div>
        </div>

        <!-- Content -->
        <div class="flex-1 overflow-y-auto bg-slate-50 p-6">
            @RenderBody()
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
